# ─────────────────────────────────────────────────────────────────────────
# DISPATCH.AI environment configuration
# Copy this file to `.env` and fill in the keys you need.
# `.env` is gitignored — never commit real secrets.
# ─────────────────────────────────────────────────────────────────────────

# ── Server ──────────────────────────────────────────────────────────────
# Port the app + websocket server listens on (default 3000).
PORT=3000

# ── Model providers ─────────────────────────────────────────────────────
# At least one provider is required to run chains. Each node can use any
# provider/model you have configured (model hotswapping).

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1

# Anthropic — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Google (Gemini) — https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# ── Agentic voice control (OpenAI Realtime) ─────────────────────────────
# Used by the VoiceOrb / Conversate panel. Optional — voice is disabled
# without it. A separate key is recommended (realtime is billed differently).
RTM_OPENAI=
RTM_OPENAI_MODEL=gpt-realtime-2
RTM_OPENAI_VOICE=marin
RTM_OPENAI_TRANSCRIPTION_MODEL=whisper-1

# ── Deploy node (Vercel) ────────────────────────────────────────────────
# Optional — only needed to use the Deploy node.
VERCEL_TOKEN=
VERCEL_PROJECT_ID=
